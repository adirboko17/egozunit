[{"id":960,"date":"2020-04-17T23:09:50","date_gmt":"2020-04-17T20:09:50","guid":{"rendered":"http:\/\/yem.okt.mybluehost.me\/?post_type=fallen&#038;p=960"},"modified":"2022-10-07T21:01:06","modified_gmt":"2022-10-07T18:01:06","slug":"avner-saadon","status":"publish","type":"fallen","link":"https:\/\/egoz.org.il\/fallen\/avner-saadon\/","title":{"rendered":"\u05d0\u05d1\u05e0\u05e8 \u05e1\u05e2\u05d3\u05d5\u05df"},"content":{"rendered":"\n<link rel=\"stylesheet\" href=\"https:\/\/egoz.org.il\/wp-content\/plugins\/fallpage\/style.css\" \/>\n<link rel=\"stylesheet\" type=\"text\/css\" href=\"https:\/\/egoz.org.il\/wp-content\/plugins\/fallpage\/slick\/slick.css\" \/>\n<link rel=\"stylesheet\" type=\"text\/css\" href=\"https:\/\/egoz.org.il\/wp-content\/plugins\/fallpage\/slick\/slick-theme.css\" \/>\n<div class=\"cont\">\n    <div class=\"space\"><\/div>\n    <div class=\"memorial_site\" id=\"cont-top\"><\/div>\n    <div class=\"cont-center\">\n        <div id=\"about\" style=\"max-height: 200px\">\n            <p><p>\u05d1\u05df \u05d0\u05d9\u05d5\u05d5\u05d8 \u05d5\u05d9\u05e2\u05e7\u05d1. \u05e0\u05d5\u05dc\u05d3 \u05d1\u05d9\u05d5\u05dd \u05db&quot;\u05d1 \u05d1\u05e9\u05d1\u05d8 \u05ea\u05e9\u05d9&quot;\u05d1<span>&nbsp;<\/span><span style=\"box-sizing: border-box;\">(18.2.1952)<\/span><span>&nbsp;<\/span>\u05d1\u05d1\u05d0\u05e8-\u05e9\u05d1\u05e2 \u05d5\u05d9\u05dc\u05d3\u05d5\u05ea\u05d5 \u05e2\u05d1\u05e8\u05d4 \u05e2\u05dc\u05d9\u05d5 \u05d1\u05de\u05d5\u05e9\u05d1 \u05d2\u05d9\u05dc\u05ea. \u05d4\u05d5\u05d0 \u05e2\u05d6\u05d1 \u05d0\u05ea \u05d4\u05d0\u05e8\u05e5 \u05e2\u05dd \u05d4\u05de\u05e9\u05e4\u05d7\u05d4, \u05e9\u05d9\u05e6\u05d0\u05d4 \u05d1\u05e9\u05dc\u05d9\u05d7\u05d5\u05ea \u05dc\u05d8\u05d5\u05e0\u05d9\u05e1\u05d9\u05d4 \u05dc\u05e9\u05e0\u05ea\u05d9\u05d9\u05dd \u05d5\u05d7\u05e6\u05d9. \u05d1-<span style=\"box-sizing: border-box;\">1958<\/span><span>&nbsp;<\/span>\u05d7\u05d6\u05e8\u05d5 \u05d1\u05e0\u05d9 \u05d4\u05de\u05e9\u05e4\u05d7\u05d4 \u05d5\u05d4\u05e9\u05ea\u05e7\u05e2\u05d5 \u05d1\u05e7\u05e8\u05d9\u05ea-\u05d2\u05ea \u05d5\u05e9\u05dd \u05d4\u05e9\u05dc\u05d9\u05dd \u05d0\u05d1\u05e0\u05e8 \u05d0\u05ea \u05dc\u05d9\u05de\u05d5\u05d3\u05d9\u05d5 \u05d4\u05d9\u05e1\u05d5\u05d3\u05d9\u05d9\u05dd \u05d5\u05d4\u05ea\u05d9\u05db\u05d5\u05e0\u05d9\u05d9\u05dd.<\/p><p>\u05d4\u05d5\u05d0 \u05d4\u05ea\u05d2\u05d9\u05d9\u05e1 \u05dc\u05e6\u05d4&quot;\u05dc \u05d1\u05d0\u05d5\u05d2\u05d5\u05e1\u05d8<span>&nbsp;<\/span><span style=\"box-sizing: border-box;\">1970<\/span>, \u05dc\u05d0\u05d7\u05e8 \u05e1\u05d9\u05d5\u05dd \u05d1\u05d7\u05d9\u05e0\u05d5\u05ea \u05d4\u05d1\u05d2\u05e8\u05d5\u05ea \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4. \u05d1\u05e6\u05d4&quot;\u05dc \u05e2\u05e9\u05d4 \u05d3\u05e8\u05db\u05d5 \u05dc\u05d0\u05d7\u05ea \u05d4\u05e1\u05d9\u05d9\u05e8\u05d5\u05ea. \u05e2\u05d1\u05e8 \u05d0\u05ea \u05e9\u05dc\u05d1\u05d9 \u05d4\u05e7\u05d9\u05d3\u05d5\u05dd \u05d1\u05d6\u05d4 \u05d0\u05d7\u05e8 \u05d6\u05d4 \u05d5\u05d7\u05d6\u05e8 \u05dc\u05d9\u05d7\u05d9\u05d3\u05ea\u05d5 \u05dc\u05d0\u05d7\u05e8 \u05e1\u05d9\u05d5\u05dd \u05e7\u05d5\u05e8\u05e1 \u05e7\u05e6\u05d9\u05e0\u05d9\u05dd.<\/p><p>\u05d0\u05e8\u05d1\u05e2\u05d4 \u05d3\u05e4\u05d9 \u05d9\u05d5\u05de\u05df \u05e9\u05db\u05ea\u05d1 \u05de\u05e2\u05d9\u05d3\u05d9\u05dd \u05e2\u05dc \u05d0\u05d5\u05e4\u05d9\u05d5. \u05db\u05ea\u05d5\u05d1 \u05d1\u05d4\u05dd \u05dc\u05d0\u05de\u05d5\u05e8: &quot;\u05dc\u05d6\u05db\u05d5\u05e8 \u05d5\u05d3\u05d1\u05e8 \u05dc\u05d0 \u05dc\u05e9\u05db\u05d5\u05d7&#8230; \u05d5\u05d1\u05de\u05d9\u05d5\u05d7\u05d3 \u05dc\u05d6\u05db\u05d5\u05e8 \u05db\u05d9 \u05d0\u05e0\u05d9 \u05d9\u05d4\u05d5\u05d3\u05d9, \u05d5\u05d1\u05e8\u05d0\u05e9 \u05d5\u05e8\u05d0\u05e9\u05d5\u05e0\u05d4 \u05e9\u05dc\u05d4\u05d9\u05d5\u05ea \u05d9\u05d4\u05d5\u05d3\u05d9 \u05d6\u05d5 \u05d6\u05db\u05d5\u05ea \u05d2\u05d3\u05d5\u05dc\u05d4 \u05d0\u05da \u05d4\u05d7\u05d5\u05d1\u05d5\u05ea \u05d2\u05d3\u05d5\u05dc\u05d5\u05ea \u05d1\u05d4\u05e8\u05d1\u05d4. \u05dc\u05d6\u05db\u05d5\u05e8 \u05db\u05d3\u05d9 \u05dc\u05d3\u05e2\u05ea \u05d5\u05dc\u05d4\u05d1\u05d9\u05df \u05e9\u05d2\u05dc\u05d2\u05dc \u05d4\u05d4\u05d9\u05e1\u05d8\u05d5\u05e8\u05d9\u05d4 \u05d4\u05d9\u05d4\u05d5\u05d3\u05d9\u05ea \u05d4\u05d1\u05d6\u05d5\u05d9\u05d4 \u05dc\u05d0 \u05d9\u05d7\u05d6\u05d5\u05e8 \u05db\u05d0\u05df, \u05dc\u05d0 \u05d1\u05d0\u05e8\u05e5 \u05d4\u05d6\u05d5, \u05dc\u05d0 \u05db\u05e9\u05d0\u05e0\u05d9 \u05d7\u05d9&#8230;&quot;<\/p><p>\u05e2\u05e8\u05d1 \u05d2\u05d9\u05d5\u05e1\u05d5 \u05e9\u05dc \u05d0\u05d7\u05d9\u05d5 \u05d7\u05d9\u05d9\u05dd, \u05db\u05ea\u05d1 \u05d0\u05d1\u05e0\u05e8 \u05dc\u05d4\u05d5\u05e8\u05d9\u05d5: &quot;\u05d0\u05e0\u05d9 \u05d9\u05d5\u05d3\u05e2 \u05e9\u05d0\u05dd \u05d9\u05d4\u05d9\u05d5 \u05e9\u05e0\u05d9 \u05d1\u05e0\u05d9\u05dd \u05dc\u05d5\u05d7\u05de\u05d9\u05dd \u05d1\u05d1\u05d9\u05ea &#8211; \u05d0\u05ea\u05dd \u05d5\u05d2\u05dd \u05d0\u05e0\u05d7\u05e0\u05d5 \u05e0\u05d4\u05d9\u05d4 \u05d2\u05d0\u05d9\u05dd \u05d9\u05d5\u05ea\u05e8&#8230; \u05d2\u05d0\u05d9\u05dd \u05d5\u05de\u05db\u05d9\u05e8\u05d9\u05dd \u05d9\u05d5\u05ea\u05e8 \u05d1\u05d7\u05d5\u05d1\u05d4 \u05d4\u05de\u05d5\u05d8\u05dc\u05ea \u05e2\u05dc\u05d9\u05e0\u05d5. \u05de\u05d3\u05d9\u05e0\u05d4 \u05db\u05e9\u05dc\u05e0\u05d5 \u05d7\u05d9\u05d9\u05d1\u05ea \u05dc\u05d2\u05d3\u05dc \u05dc\u05d5\u05d7\u05de\u05d9\u05dd \u05db\u05d3\u05d9 \u05dc\u05d4\u05de\u05e9\u05d9\u05da \u05d5\u05dc\u05d4\u05ea\u05e7\u05d9\u05d9\u05dd \u05d5\u05d6\u05d4 \u05d4\u05d7\u05dc\u05e7 \u05e9\u05d0\u05e0\u05d5 \u05de\u05e9\u05dc\u05de\u05d9\u05dd. \u05d0\u05d1\u05d0, \u05de\u05ea\u05ea\u05d9\u05d4\u05d5-\u05d4\u05d7\u05e9\u05de\u05d5\u05e0\u05d0\u05d9 \u05d2\u05d9\u05d3\u05dc \u05e8\u05e7 \u05dc\u05d5\u05d7\u05de\u05d9\u05dd \u05de\u05ea\u05d5\u05da \u05d4\u05db\u05e8\u05d4 \u05e9\u05d1\u05d4\u05db\u05e8\u05d7&quot;.<\/p><p>\u05d0\u05d1\u05e0\u05e8 \u05e0\u05d9\u05db\u05e8 \u05d1\u05e2\u05e7\u05e9\u05e0\u05d5\u05ea\u05d5 \u05d5\u05d1\u05d3\u05d1\u05e7\u05d5\u05ea\u05d5 \u05d1\u05de\u05d8\u05e8\u05d4. \u05d4\u05d5\u05d0 \u05dc\u05d0 \u05d4\u05e9\u05dc\u05d9\u05dd \u05e2\u05dd \u05d4\u05de\u05d5\u05e1\u05db\u05de\u05d5\u05ea \u05e9\u05dc \u05d4\u05d7\u05d1\u05e8\u05d4 \u05d5\u05e2\u05dd \u05d4\u05e9\u05d2\u05e8\u05d4, \u05d0\u05d5 \u05e2\u05dd \u05e0\u05d8\u05d9\u05e9\u05ea \u05e2\u05d9\u05e7\u05e8\u05d5\u05df \u05dc\u05de\u05e2\u05df \u05e0\u05d5\u05d7\u05d5\u05ea. \u05d4\u05d5\u05d0 \u05d4\u05e9\u05dc\u05d9\u05dd \u05e2\u05dd \u05de\u05e6\u05d9\u05d0\u05d5\u05ea \u05d4\u05d7\u05d9\u05d9\u05dd \u05d5\u05d4\u05d0\u05de\u05d9\u05df \u05e9\u05d1\u05db\u05d3\u05d9 \u05dc\u05d4\u05e6\u05dc\u05d9\u05d7 \u05dc\u05e9\u05e0\u05d5\u05ea \u05d3\u05d1\u05e8\u05d9\u05dd \u05d9\u05e9 \u05e6\u05d5\u05e8\u05da \u05dc\u05e8\u05db\u05d5\u05e9 \u05e2\u05de\u05d3\u05d5\u05ea \u05db\u05d5\u05d7 \u05de\u05d4\u05df \u05d9\u05d5\u05db\u05dc \u05dc\u05d4\u05e9\u05e4\u05d9\u05e2. \u05d4\u05d5\u05d0 \u05d4\u05d9\u05d4 \u05de\u05e1\u05d5\u05e8 \u05dc\u05d7\u05d9\u05d9\u05dc\u05d9\u05d5 \u05d5\u05d7\u05dc\u05e7 \u05de\u05d6\u05de\u05e0\u05d5 \u05e2\u05e9\u05d4 \u05d1\u05d1\u05d9\u05e7\u05d5\u05e8\u05d9 \u05d1\u05d9\u05ea \u05d0\u05e6\u05dc \u05d7\u05d9\u05d9\u05dc\u05d9\u05d5, \u05d1\u05e0\u05d9\u05e1\u05d9\u05d5\u05df \u05dc\u05e4\u05ea\u05d5\u05e8 \u05d1\u05e2\u05d9\u05d5\u05ea \u05d0\u05d9\u05e9\u05d9\u05d5\u05ea \u05d5\u05db\u05dc\u05db\u05dc\u05d9\u05d5\u05ea. \u05db\u05de\u05e4\u05e7\u05d3 \u05d7\u05d9\u05e4\u05e9 \u05d0\u05d1\u05e0\u05e8 \u05d3\u05e8\u05db\u05d9\u05dd \u05dc\u05d7\u05d3\u05e9, \u05dc\u05e9\u05db\u05dc\u05dc, \u05dc\u05e9\u05e4\u05e8 \u05d5\u05dc\u05d9\u05d9\u05e2\u05dc. \u05d1\u05de\u05e1\u05e2\u05d5\u05ea \u05d4\u05d9\u05d4 \u05e0\u05d5\u05d4\u05d2 \u05dc\u05e0\u05d5\u05d5\u05d8 \u05d1\u05e2\u05e6\u05de\u05d5, \u05db\u05d3\u05d9 \u05dc\u05de\u05e0\u05d5\u05e2 \u05e0\u05e4\u05d9\u05dc\u05ea \u05e7\u05d5\u05e8\u05d1\u05e0\u05d5\u05ea \u05d1\u05d2\u05dc\u05dc \u05d8\u05e2\u05d5\u05ea \u05d1\u05e0\u05d9\u05d5\u05d5\u05d8.<\/p><p>\u05d4\u05d5\u05d0 \u05d4\u05e9\u05ea\u05ea\u05e3 \u05d1\u05e4\u05e2\u05d5\u05dc\u05d5\u05ea \u05e8\u05d1\u05d5\u05ea \u05de\u05e2\u05d1\u05e8 \u05dc\u05d2\u05d1\u05d5\u05dc \u05d5\u05e0\u05e4\u05dc \u05d1\u05e4\u05e9\u05d9\u05d8\u05d4 \u05e2\u05dc \u05e7\u05e0\u05d9 \u05de\u05d7\u05d1\u05dc\u05d9\u05dd \u05d1\u05de\u05d1\u05d5\u05d0\u05d5\u05ea \u05d4\u05db\u05e4\u05e8 \u05d2'\u05d5\u05d0\u05d9\u05d4 \u05d1\u05d9\u05d5\u05dd \u05d7' \u05d1\u05ea\u05e9\u05e8\u05d9 \u05ea\u05e9\u05dc&quot;\u05d2<span>&nbsp;<\/span><span style=\"box-sizing: border-box;\">(16.9.1972)<\/span>. \u05d4\u05d5\u05d1\u05d0 \u05dc\u05de\u05e0\u05d5\u05d7\u05ea-\u05e2\u05d5\u05dc\u05de\u05d9\u05dd \u05d1\u05d7\u05dc\u05e7\u05d4 \u05d4\u05e6\u05d1\u05d0\u05d9\u05ea \u05d1\u05d1\u05d9\u05ea-\u05d4\u05e7\u05d1\u05e8\u05d5\u05ea \u05d1\u05e7\u05e8\u05d9\u05ea-\u05d2\u05ea \u05e2\u05e8\u05d1 \u05d9\u05d5\u05dd \u05db\u05d9\u05e4\u05d5\u05e8 \u05ea\u05e9\u05dc&quot;\u05d2. \u05dc\u05d0\u05d7\u05e8 \u05de\u05d5\u05ea\u05d5 \u05d4\u05d5\u05e2\u05dc\u05d4 \u05dc\u05d3\u05e8\u05d2\u05ea \u05e1\u05d2\u05df.<\/p><\/p>\n        <\/div>\n        <a class=\"readMore\" onclick=\"moreInfo(this)\">\u05e7\u05e8\u05d9\u05d0\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea\n            <span class=\"material-icons-outlined\">keyboard_arrow_down<\/span><\/a>\n    <\/div>\n    <div class=\"space\"><\/div>\n    <div class=\"scroll-gallery\">\n        <div id=\"img-gallery\" dir=\"rtl\"><\/div>\n    <\/div>\n    <div class=\"space\"><\/div>\n    <div class=\"memorial_site\">\n        <h3>\u05d0\u05ea\u05e8 \u05d4\u05d4\u05e0\u05e6\u05d7\u05d4 \u05dc\u05d7\u05dc\u05dc\u05d9 \u05e1\u05d9\u05d9\u05e8\u05ea '\u05d0\u05d2\u05d5\u05d6'<\/h3>\n        <a id=\"navigate-main\" href=\"https:\/\/goo.gl\/maps\/1gZWWfNbwB1eVCiR9\" target=\"_blank\" rel=\"noopener\"><span class=\"material-icons-outlined\"> place\n            <\/span>\n            \u05e0\u05d9\u05d5\u05d5\u05d8 \u05dc\u05d0\u05ea\u05e8<\/a>\n    <\/div>\n    <div class=\"cont-center\">\n        <div id=\"about-mem\" style=\"max-height: 275px\">\n            <div class=\"text\">\n                <p>\n                    \u05dc\u05d4\u05e7\u05de\u05ea \u05d0\u05ea\u05e8 \u05d4\u05d4\u05e0\u05e6\u05d7\u05d4 \u05dc\u05d7\u05dc\u05dc\u05d9 \u05e1\u05d9\u05d9\u05e8\u05ea '\u05d0\u05d2\u05d5\u05d6' \u05e0\u05d5\u05dc\u05d3\u05d4 \u05d1\u05d9\u05d9\u05e9\u05d5\u05d1 \u05e0\u05d5\u05d5\u05d4 \u05d0\u05d8\u05d9&quot;\u05d1,\n                    \u05d4\u05e0\u05e7\u05e8\u05d0\u05ea \u05e2&quot;\u05e9 \u05d7\u05dc\u05dc\u05d9 '\u05d0\u05d2\u05d5\u05d6'. \u05d0\u05ea\u05e8 \u05d4\u05d4\u05e0\u05e6\u05d7\u05d4 \u05d1\u05e7\u05dc\u05e2\u05ea \u05e0\u05de\u05e8\u05d5\u05d3 \u05d4\u05d5\u05e7\u05dd \u05d1\u05e9\u05e0\u05ea 1973 &#8211;\n                    <a href=\"https:\/\/egoz.org.il\/wp-content\/uploads\/2022\/04\/NuritLissovskiLR.pdf\" target=\"_blank\" rel=\"noopener\">\u05e1\u05d9\u05e4\u05d5\u05e8\u05d5\n                        \u05d4\u05de\u05dc\u05d0\n                        \u05d5\u05ea\u05e6\u05dc\u05d5\u05de\u05d9 \u05d4\u05d0\u05d5\u05d5\u05d9\u05e8<\/a>\n                    \u05d1\u05d0\u05ea\u05e8 \u05de\u05d5\u05e0\u05e6\u05d7\u05d9\u05dd \u05db\u05dc\u05dc \u05e0\u05d5\u05e4\u05dc\u05d9 \u05d9\u05d7\u05d9\u05d3\u05ea \u05d0\u05d2\u05d5\u05d6 \u05de\u05d0\u05d6 \u05d4\u05e7\u05de\u05ea\u05d4 \u05d1\u05e9\u05e0\u05ea 1956 \u05d5\u05e2\u05d3 \u05d4\u05d9\u05d5\u05dd.\n                <\/p>\n                <p>\u05de\u05d9\u05d3\u05d9 \u05e9\u05e0\u05d4, \u05de\u05ea\u05e7\u05d9\u05d9\u05de\u05d9\u05dd \u05d1\u05d0\u05ea\u05e8 \u05d4\u05d4\u05e0\u05e6\u05d7\u05d4 \u05d4\u05d0\u05d9\u05e8\u05d5\u05e2\u05d9\u05dd \u05d4\u05d1\u05d0\u05d9\u05dd:<\/p>\n                <ul>\n                    <li>3 \u05d8\u05e7\u05e1\u05d9 \u05e1\u05d5\u05e3 \u05de\u05e1\u05dc\u05d5\u05dc \u05e9\u05dc \u05dc\u05d5\u05d7\u05de\u05d9 \u05d4\u05d9\u05d7\u05d9\u05d3\u05d4 \u05d5\u05d1\u05e0\u05d9 \u05de\u05e9\u05e4\u05d7\u05d5\u05ea\u05d9\u05d4\u05dd.<\/li>\n                    <li>3 \u05d1\u05d9\u05e7\u05d5\u05e8\u05d9\u05dd \u05e9\u05dc \u05d7\u05d9\u05d9\u05dc\u05d9 \u05d4\u05d9\u05d7\u05d9\u05d3\u05d4 \u05d1\u05d7\u05d5\u05d3\u05e9\u05d9\u05dd \u05d4\u05e8\u05d0\u05e9\u05d5\u05e0\u05d9\u05dd \u05dc\u05d0\u05d7\u05e8 \u05d2\u05d9\u05d5\u05e1\u05dd.<\/li>\n                    <li>\n                        \u05d8\u05e7\u05e1 \u05d4\u05e0\u05e6\u05d7\u05d4 \u05e6\u05d4&quot;\u05dc\u05d9 \u05dc\u05d6\u05db\u05e8 \u05d7\u05dc\u05dc\u05d9 \u05d4\u05d9\u05d7\u05d9\u05d3\u05d4 \u05e2\u05dd \u05dc\u05d5\u05d7\u05de\u05d9 \u05d4\u05d9\u05d7\u05d9\u05d3\u05d4, \u05d4\u05de\u05e9\u05e4\u05d7\u05d5\u05ea\n                        \u05d4\u05e9\u05db\u05d5\u05dc\u05d5\u05ea, \u05d5\u05db\u05dc \u05d4\u05d1\u05d5\u05d2\u05e8\u05d9\u05dd \u05de\u05d0\u05d6 \u05d4\u05e7\u05de\u05ea\u05d4 (\u05d1\u05d7\u05d5\u05dc \u05d4\u05de\u05d5\u05e2\u05d3 \u05e1\u05d5\u05db\u05d5\u05ea).\n                    <\/li>\n                <\/ul>\n                <p>\n                    \u05d1\u05d9\u05e7\u05d5\u05e8\u05d9 \u05d4\u05ea\u05d9\u05d9\u05d7\u05d3\u05d5\u05ea \u05e9\u05dc \u05d4\u05de\u05e9\u05e4\u05d7\u05d5\u05ea \u05d4\u05e9\u05db\u05d5\u05dc\u05d5\u05ea \u05e2\u05dd \u05d9\u05e7\u05d9\u05e8\u05d9\u05d4\u05df \u05e9\u05e0\u05e4\u05dc\u05d5. \u05de\u05d1\u05e7\u05e8\u05d9\u05dd \u05e8\u05d1\u05d9\u05dd\n                    \u05d0\u05e9\u05e8 \u05de\u05d2\u05d9\u05e2\u05d9\u05dd \u05dc\u05d9\u05d4\u05e0\u05d5\u05ea \u05de\u05d4\u05e0\u05d5\u05e3 \u05d5\u05dc\u05dc\u05de\u05d5\u05d3 \u05e2\u05dc \u05d9\u05d7\u05d9\u05d3\u05ea \u05d0\u05d2\u05d5\u05d6 \u05d5\u05dc\u05d5\u05d7\u05de\u05d9\u05d4 \u05e9\u05e0\u05e4\u05dc\u05d5 \u05e2\u05dc \u05d4\u05d2\u05e0\u05ea\n                    \u05d4\u05d0\u05e8\u05e5.\n                <\/p>\n                <p>\n                    \u05d0\u05ea\u05e8 \u05d4\u05d4\u05e0\u05e6\u05d7\u05d4 \u05d4\u05d5\u05e7\u05dd \u05e2\u05dc \u05d9\u05d3\u05d9 \u05d1\u05d5\u05d2\u05e8\u05d9 \u05d4\u05d9\u05d7\u05d9\u05d3\u05d4 \u05d5\u05de\u05ea\u05d5\u05d7\u05d6\u05e7 \u05d1\u05d4\u05ea\u05e0\u05d3\u05d1\u05d5\u05ea \u05de\u05dc\u05d0\u05d4 \u05dc\u05de\u05e2\u05dc\u05d4\n                    \u05de-40 \u05e9\u05e0\u05d4, \u05dc\u05dc\u05d0 \u05ea\u05de\u05d9\u05db\u05d4 \u05de\u05d2\u05d5\u05e8\u05de\u05d9\u05dd \u05d7\u05d9\u05e6\u05d5\u05e0\u05d9\u05d9\u05dd.\n                <\/p>\n            <\/div>\n            <img decoding=\"async\" src=\"https:\/\/egoz.org.il\/wp-content\/uploads\/2022\/09\/\u05d1\u05d5\u05dc\u05d3\u05e8-\u05d0\u05d1\u05e0\u05e8-\u05e1\u05e2\u05d3\u05d5\u05df-2-scaled.jpg\" \/>\n        <\/div>\n        <a class=\"readMore\" onclick=\"moreInfoMem(this)\">\u05e7\u05e8\u05d9\u05d0\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea\n            <span class=\"material-icons-outlined\">keyboard_arrow_down<\/span><\/a>\n    <\/div>\n    <div class=\"space\"><\/div>\n\n    <h3>\u05d0\u05ea\u05e8\u05d9 \u05d4\u05e0\u05e6\u05d7\u05d4 \u05e2\u05dc \u05e9\u05dd \u05d4\u05e0\u05d5\u05e4\u05dc<\/h3>\n    <div class=\"cont-center\">\n        <div id=\"sites\" style=\"max-height: 200px\"><\/div>\n        <a class=\"readMore\" onclick=\"moreSites(this)\">\u05e7\u05e8\u05d9\u05d0\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea\n            <span class=\"material-icons-outlined\">keyboard_arrow_down<\/span><\/a>\n    <\/div>\n    <div class=\"space\"><\/div>\n    <div class=\"horizon_center\">\n        <h3>\u05db\u05ea\u05d1\u05d5 \u05e2\u05dc \u05d0\u05d1\u05e0\u05e8<\/h3>\n    <\/div>\n    <div class=\"horizon_center\">\n        \n    <\/div>\n    <div class=\"space\"><\/div>\n    <div class=\"horizon_center\">\n        <h3>\u05de\u05e1\u05e8 \u05de\u05d4\u05de\u05e9\u05e4\u05d7\u05d4<\/h3>\n        <a class=\"addNote\" onclick=\"addFamilyNote()\">\u05d4\u05d5\u05e1\u05e4\u05d4 <span class=\"material-icons-outlined\">add<\/span><\/a>\n    <\/div>\n    <div class=\"scroll-gallery\">\n        <div id=\"family-note-gallery\" dir=\"rtl\"><\/div>\n    <\/div>\n    <div class=\"space\"><\/div>\n    <div class=\"horizon_center\">\n        <h3>\u05db\u05ea\u05d1\u05d5 \u05dc\u05de\u05e9\u05e4\u05d7\u05ea \u05e1\u05e2\u05d3\u05d5\u05df<\/h3>\n        <a class=\"addNote\" onclick=\"addNote()\">\u05d4\u05d5\u05e1\u05e4\u05d4 <span class=\"material-icons-outlined\">add<\/span><\/a>\n    <\/div>\n    <div class=\"vertical_center\">\n        <div class=\"scrolldown-gallery\" id=\"note-gallery\" style=\"left: 0px\"><\/div>\n        <a class=\"readMore\" id=\"read-more-notes\" style=\"display: none\" onclick=\"moreNotes(this)\">\u05e7\u05e8\u05d9\u05d0\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea\n            <span class=\"material-icons-outlined\">keyboard_arrow_down<\/span><\/a>\n    <\/div>\n\n    <div class=\"space\"><\/div>\n<\/div>\n\n<div id=\"full_screen\">\n    <div id=\"full_background\" onclick=\"closeFullscreen();\"><\/div>\n    <div id=\"full_center\">\n        <div id=\"full_note\">\n            <p>\n                <span class=\"note_name\">\u05e9\u05dd<\/span>\n                <span class=\"note_site\">\u05e9\u05dd \u05d4\u05d0\u05ea\u05e8<\/span>\n            <\/p>\n            <p class=\"note_text\">\u05ea\u05d5\u05db\u05df \u05d4\u05d5\u05d3\u05e2\u05d4<\/p>\n            <button class=\"note_close\" onclick=\"closeFullscreen()\">\u05e1\u05d2\u05d5\u05e8<\/button>\n        <\/div>\n        <div id=\"full_form\">\n            <p>\u05d0\u05ea\u05dd \u05de\u05d5\u05d6\u05de\u05e0\u05d9\u05dd \u05dc\u05db\u05ea\u05d5\u05d1 \u05dc\u05de\u05e9\u05e4\u05d7\u05d4<\/p>\n            <input type=\"text\" name=\"name\" value=\"\" placeholder=\"\u05e9\u05dd\" \/>\n            <select class=\"\" name=\"siteName\">\n                <option value=\"9\">\u05e9\u05dd \u05d4\u05d0\u05ea\u05e8<\/option>\n                <option value=\"10\">\u05e9\u05dd \u05d4\u05d0\u05ea\u05e8 2<\/option>\n            <\/select>\n            <textarea name=\"content\" rows=\"8\" cols=\"80\" placeholder=\"\u05ea\u05d5\u05db\u05df \u05d4\u05de\u05db\u05ea\u05d1\"><\/textarea>\n            <div class=\"horizon_center\">\n                <button class=\"note_submit\" onclick=\"submit()\">\u05e9\u05dc\u05d7<\/button>\n                <button class=\"note_close\" onclick=\"closeFullscreen()\">\u05e1\u05d2\u05d5\u05e8<\/button>\n            <\/div>\n        <\/div>\n        <div id=\"family_full_form\">\n            <p>\u05de\u05e9\u05e4\u05d7\u05d4 \u05d9\u05e7\u05e8\u05d4,<\/p>\n            <p>\u05d0\u05ea\u05dd \u05de\u05d5\u05d6\u05de\u05e0\u05d9\u05dd \u05dc\u05db\u05ea\u05d5\u05d1 \u05db\u05d0\u05df<\/p>\n            <input type=\"text\" name=\"name\" value=\"\" placeholder=\"\u05e9\u05dd\" \/>\n            <textarea name=\"content\" rows=\"8\" cols=\"80\" placeholder=\"\u05ea\u05d5\u05db\u05df \u05d4\u05de\u05db\u05ea\u05d1\"><\/textarea>\n            <div class=\"horizon_center\">\n                <button class=\"note_submit\" onclick=\"submit_family()\">\u05e9\u05dc\u05d7<\/button>\n                <button class=\"note_close\" onclick=\"closeFullscreen()\">\u05e1\u05d2\u05d5\u05e8<\/button>\n            <\/div>\n        <\/div>\n    <\/div>\n<\/div>\n<div id=\"fullpage-img\">\n    <div class=\"close-fullpage\">\n        <button onclick=\"fullpage('close')\">\n            <span class=\"material-icons-outlined\">close<\/span>\n        <\/button>\n    <\/div>\n    <div id=\"img-gallery-fullpage\" dir=\"rtl\"><\/div>\n<\/div>\n<script type=\"text\/javascript\" src=\"https:\/\/egoz.org.il\/wp-content\/plugins\/fallpage\/jquery-3.6.0.min.js\"><\/script>\n<script type=\"text\/javascript\" src=\"https:\/\/egoz.org.il\/wp-content\/plugins\/fallpage\/slick\/slick.min.js\"><\/script>\n<script>\n\n    $('#cont-top').html(`<h3>\u05e2\u05dc \u05d4\u05e0\u05d5\u05e4\u05dc<\/h3>\n    <a id=\"candle\" href=\"https:\/\/www.izkor.gov.il\/%D7%90%D7%91%D7%A0%D7%A8%20%D7%A1%D7%A2%D7%93%D7%95%D7%9F\/en_defd05e372b92398ec57039d6fb65e43\" target=\"_blank\"><span class=\"material-icons-outlined\"> fireplace <\/span> \u05d4\u05d3\u05dc\u05e7\u05ea\n      \u05e0\u05e8\n      \u05d6\u05d9\u05db\u05e8\u05d5\u05df<\/a>`);\n    $('#img-gallery').slick({\n        dots: true,\n        infinite: true,\n        speed: 800,\n        slidesToShow: 1,\n        centerMode: true,\n        rtl: true,\n        arrows: false,\n        autoplay: true,\n        autoplaySpeed: 3500,\n        variableWidth: true,\n        asNavFor: '#img-gallery-fullpage'\n    });\n\n    $('#img-gallery-fullpage').slick({\n        slidesToShow: 1,\n        slidesToScroll: 1,\n        arrows: true,\n        rtl: true,\n        fade: true,\n        asNavFor: '#img-gallery'\n    });\n\n    function fullpage(ind) {\n        var fp = document.getElementById('fullpage-img');\n        if (ind != \"close\") {\n            $('#img-gallery').slick('slickPause');\n            setTimeout(function () {\n                fp.style.visibility = \"visible\";\n                setTimeout(function () {\n                    fp.style.opacity = 1;\n                }, 10);\n            }, 500);\n        } else {\n            $('#img-gallery').slick('slickPlay');\n            fp.style.opacity = 0;\n            setTimeout(function () {\n                fp.style.visibility = \"hidden\";\n            }, 500);\n        }\n    }\n\n    function moreInfo(button) {\n        var div = document.getElementById('about');\n        if (div.style['max-height'] != \"200px\") {\n            div.style['max-height'] = \"200px\";\n            button.innerHTML = `\u05e7\u05e8\u05d9\u05d0\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea <span class=\"material-icons-outlined\">keyboard_arrow_down<\/span>`;\n        } else {\n            div.style['max-height'] = div.scrollHeight + \"px\";\n            button.innerHTML = `\u05d4\u05e1\u05ea\u05e8\u05d4 <span class=\"material-icons-outlined\">keyboard_arrow_up<\/span>`;\n        }\n    }\n\n    function moreInfoMem(button) {\n        var div = document.getElementById('about-mem');\n        if (div.style['max-height'] != \"275px\") {\n            div.style['max-height'] = \"275px\";\n            button.innerHTML = `\u05e7\u05e8\u05d9\u05d0\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea <span class=\"material-icons-outlined\">keyboard_arrow_down<\/span>`;\n        } else {\n            div.style['max-height'] = div.scrollHeight + \"px\";\n            button.innerHTML = `\u05d4\u05e1\u05ea\u05e8\u05d4 <span class=\"material-icons-outlined\">keyboard_arrow_up<\/span>`;\n        }\n    }\n\n    function moreSites(button) {\n        var div = document.getElementById('sites');\n        if (div.style['max-height'] != \"200px\") {\n            div.style['max-height'] = \"200px\";\n            button.innerHTML = `\u05e7\u05e8\u05d9\u05d0\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea <span class=\"material-icons-outlined\">keyboard_arrow_down<\/span>`;\n        } else {\n            div.style['max-height'] = div.scrollHeight + \"px\";\n            button.innerHTML = `\u05d4\u05e1\u05ea\u05e8\u05d4 <span class=\"material-icons-outlined\">keyboard_arrow_up<\/span>`;\n        }\n    }\n\n    function moreNotes(button) {\n        var div = document.getElementById('note-gallery');\n        if (div.style['max-height'] != div.scrollHeight + \"px\") {\n            div.style['max-height'] = Math.min(div.clientHeight + 450, div.scrollHeight) + \"px\";\n            if (div.style['max-height'] == div.scrollHeight + \"px\") {\n                button.innerHTML = `\u05d4\u05e1\u05ea\u05e8\u05d4 <span class=\"material-icons-outlined\">keyboard_arrow_up<\/span>`;\n            } else {\n                button.innerHTML = `\u05e7\u05e8\u05d9\u05d0\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea <span class=\"material-icons-outlined\">keyboard_arrow_down<\/span>`;\n            }\n        } else {\n            div.style['max-height'] = \"255px\";\n            button.innerHTML = `\u05e7\u05e8\u05d9\u05d0\u05d4 \u05e0\u05d5\u05e1\u05e4\u05ea <span class=\"material-icons-outlined\">keyboard_arrow_down<\/span>`;\n        }\n    }\n\n    function closeFullscreen() {\n        document.getElementById('full_background').style.display = \"none\";\n        document.getElementById('full_screen').style.display = \"none\";\n        document.body.style['overflow-y'] = \"scroll\";\n    }\n\n    function fullNote(button) {\n        openFullScreen(\"full_note\");\n        var div = document.getElementById('full_note');\n        var sourceDiv = button.parentNode;\n        div.querySelector('.note_name').innerHTML = sourceDiv.querySelector('.note_name').innerHTML;\n        if (sourceDiv.querySelector('.note_site')) {\n            div.querySelector('.note_site').innerHTML = sourceDiv.querySelector('.note_site').innerHTML;\n        } else {\n            div.querySelector('.note_site').innerHTML = \"\";\n        }\n        div.querySelector('.note_text').innerHTML = sourceDiv.querySelector('.note_msg').innerHTML;\n    }\n\n    function addNote() {\n        openFullScreen(\"full_form\");\n    }\n\n    function addFamilyNote() {\n        openFullScreen(\"family_full_form\");\n    }\n\n    function openFullScreen(id) {\n        document.getElementById('full_background').style.display = \"block\";\n        var div = document.getElementById('full_center');\n        for (divChild of div.children) {\n            if (divChild.id == id) {\n                divChild.style.display = \"flex\";\n            } else {\n                divChild.style.display = \"none\";\n            }\n        }\n        document.getElementById('full_screen').style.display = \"flex\";\n        document.body.style['overflow-y'] = \"hidden\";\n    }\n\n\n    function submit() {\n        var form = document.getElementById('full_form');\n        var name = form.querySelector('input[name=\"name\"]').value;\n        var site = form.querySelector('select[name=\"siteName\"]').value;\n        var siteName = form.querySelector('option[value=\"' + site + '\"]').innerHTML;\n        var text = form.querySelector('textarea[name=\"content\"]').value;\n        const xhttp = new XMLHttpRequest();\n        var params = {\n            op: \"add_note\",\n            name: name.replaceAll('\\'', '\\\\\\''),\n            site: site,\n            text: text.replaceAll('\\'', '\\\\\\''),\n            fall: 62\n          };\n    xhttp.onload = function () {\n        if (this.responseText != \"false\") {\n            document.getElementById('full_form').innerHTML = `\n                <p>\u05e0\u05e9\u05dc\u05d7 \u05d1\u05d4\u05e6\u05dc\u05d7\u05d4 <\/p>\n                <div class=\"horizon_center\">\n                <button class=\"note_close\" onclick=\"location.reload();\">\u05e1\u05d2\u05d5\u05e8<\/button>\n                <\/div>\n                `;\n        } else {\n            document.getElementById('full_form').innerHTML = `\n                <p>\u05e9\u05d2\u05d9\u05d0\u05d4 \u05d1\u05e9\u05dc\u05d9\u05d7\u05d4. \u05e0\u05e1\u05d5 \u05e9\u05d5\u05d1 \u05de\u05d0\u05d5\u05d7\u05e8 \u05d9\u05d5\u05ea\u05e8<\/p>\n                <div class=\"horizon_center\">\n                <button class=\"note_close\" onclick=\"closeFullscreen()\">\u05e1\u05d2\u05d5\u05e8<\/button>\n                <\/div>\n                `;\n        }\n    }\n    xhttp.open(\"POST\", \"https:\/\/egoz.org.il\/wp-content\/plugins\/fallpage\/info.php\", true);\n    xhttp.setRequestHeader('Content-type', 'application\/json');\n    xhttp.send(JSON.stringify(params));\n      }\n\n    function padNumber(num) {\n        if (num < 10)\n            return '0' + num;\n        return num;\n    }\n\n    function dateFormat(dateString) {\n        var date = new Date(dateString);\n        return padNumber(date.getDate()) + '\/' + padNumber(date.getMonth() + 1) + '\/' + (date.getFullYear() % 100) + ' ' + padNumber(date.getHours()) + ':' + padNumber(date.getMinutes());\n    }\n    (() => {\n        const xhttp = new XMLHttpRequest();\n        var params = {\n            op: \"get_notes\",\n            id: 62\n          };\n    xhttp.onload = function () {\n        if (this.responseText != \"false\") {\n            notes = JSON.parse(this.responseText);\n            var html = \"\";\n            if (notes.length > 0) {\n                for (note of notes) {\n                    html += `<div class=\"note\"><div>\n                    <p class=\"note_msg\">` + note.text.replaceAll(\"\\n\", \"<br>\") + `\n                    <\/p>\n                    <a class=\"continue_read\" onclick=\"fullNote(this)\">\u05d4\u05e6\u05d2 \u05ea\u05d5\u05db\u05df \u05de\u05dc\u05d0<\/a>\n                    <p>\n\n                    <span class=\"note_name\">` + note.name + `<\/span>\n                    <span class=\"note_site\">| ` + note.site + `<\/span>\n                    <span class=\"note_date\">| ` + dateFormat(note.created) + `<\/span>\n                    <\/p>\n                    <\/div>\n                    <\/div>`;\n                }\n                document.getElementById('read-more-notes').style.display = \"flex\";\n                document.getElementById('note-gallery').innerHTML = html;\n            } else {\n                document.getElementById('note-gallery').parentNode.style.display = \"none\";\n            }\n        } else {\n            document.getElementById('note-gallery').parentNode.style.display = \"none\";\n        }\n    }\n    xhttp.open(\"POST\", \"https:\/\/egoz.org.il\/wp-content\/plugins\/fallpage\/info.php\", true);\n    xhttp.setRequestHeader('Content-type', 'application\/json');\n    xhttp.send(JSON.stringify(params));\n      }) ();\n\n\n\n    function submit_family() {\n        var form = document.getElementById('family_full_form');\n        var name = form.querySelector('input[name=\"name\"]').value;\n        var text = form.querySelector('textarea[name=\"content\"]').value;\n        const xhttp = new XMLHttpRequest();\n        var params = {\n            op: \"add_family_note\",\n            name: name.replaceAll('\\'', '\\\\\\''),\n            text: text.replaceAll('\\'', '\\\\\\''),\n            fall: 62\n          };\n    xhttp.onload = function () {\n       